# ─── Server ────────────────────────────────────────────────────
PORT=5000
NODEENV=development

# ─── Database (MySQL) ──────────────────────────────────────────
DBHOST=localhost
DBUSER=root
DBPASS=
DBNAME=kirana_pos
DBPORT=3306

# ─── Authentication ───────────────────────────────────────────
JWTSECRET=generate_a_long_random_string_here

# ─── AI / OCR ─────────────────────────────────────────────────
GEMINIAPIKEY=your_gemini_api_key

# ─── CORS (comma-separated allowed origins) ───────────────────
# Leave empty to use defaults (localhost dev ports)
CORS_ORIGIN=

# ─── Email Notifications (Optional) ──────────────────────────
# SMTPHOST=smtp.gmail.com
# SMTPPORT=587
# SMTPUSER=your_email@gmail.com
# SMTPPASS=your_app_password
# NOTIFYEMAIL=target_email@gmail.com

# ─── WhatsApp / Twilio (Optional) ─────────────────────────────
# TWILIOSID=your_twilio_sid
# TWILIOTOKEN=your_twilio_token
